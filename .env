# ----- プロジェクト基本設定 -----
PROJECT_NAME="Memo Application"

# ----- 環境設定 -----
# Environment: local, staging, production
ENVIRONMENT=local

# ----- PostgreSQL 設定 -----
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ----- Docker イメージ名 -----
DOCKER_IMAGE_BACKEND=backend

# ----- ログ設定 -----
LOG_LEVEL=WARNING
LOG_FORMAT=json
